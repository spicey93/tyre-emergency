        "@context": "http://schema.org",
        "@type": "LocalBusiness",
        "name": "Tyre Emergency",
        "image": "https://tyreemergency.com/logos/logo.png",
        "telephone": "0330 133 9311",
        "email": "contact@tyreemergency.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "41 Sir Brian Way",
          "addressLocality": "Bilsthorpe",
          "addressRegion": "Newark",
          "postalCode": "NG22 8GA",
          "addressCountry": "UK"
        },
        "url": "https://tyreemergency.com",
        "logo": "https://tyreemergency.com/logos/logo.png",
        "description": "Tyre Emergency provides fast and reliable mobile tyre fitting services in the Newark area.",
        "openingHours": ["Mo-Su 00:00-23:59"],
        "sameAs": ["https://www.facebook.com/tyreemergencyltd"],
        "paymentAccepted": ["Cash", "Credit Card", "Debit Card"],
        "priceRange": "$$",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "53.136719",
          "longitude": "-1.032436"
        }
      }
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MC27JVL7"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <header
      class="container py-5 d-flex justify-content-between align-items-center"
    >
      <a href="/">
        <img src="/logos/logo.png" alt="logo symbol" width="200" />
      </a>
      <div class="flex-column d-none d-md-flex">
        <p class="h5">Call For 24 Hour Assistance</p>
        <a href={`tel:$03301339311`} class="call-btn"
          ><i class="bi bi-telephone-fill me-2"></i>0330 133 9311</a
        >
      </div>
      <a href={`tel:03301339311`} class="d-md-none call-btn"
        ><i class="bi bi-telephone-fill"></i></a
      >
    </header>

    <section id="hero">
      <div
        class="container d-flex flex-column align-items-center justify-content-center text-center text-md-start"
      >
        <!-- <p class="fs-3 mb-1">We Come to You</p> -->

        <p class="fw-bold display-5 mb-3 text-center">
          24/7 Mobile Tyre Service
        </p>
        <p class="lead fs-3 mb-3">We Come to You - 60 Minute Arrival Time</p>

        <div class="d-none d-lg-block">
          <script
            defer
            async
            src="https://cdn.trustindex.io/loader.js?7879b9e328722239bd2655baba4"
          ></script>
        </div>

        <div class="d-flex flex-column align-items-center mt-3">
          <a
            href={`tel:03301339311`}
            class="btn btn-primary btn-lg d-none d-lg-block fw-bold"
            ><i class="bi bi-telephone-fill me-2"></i>0330 133 9311</a
          >
          <a
            href={`tel:03301339311`}
            class="btn btn-primary btn-lg d-lg-none fw-bold"
            ><i class="bi bi-telephone-fill me-2"></i>Call Us For a Quote</a
          >
        </div>
        <div class="d-lg-none">
          <script
            defer
            async
            src="https://cdn.trustindex.io/loader.js?7879b9e328722239bd2655baba4"
          ></script>
        </div>
      </div>
    </section>

    <section class="py-5 bg-light">
      <div class="container">
        <script
          defer
          async
          src="https://cdn.trustindex.io/loader.js?ef1dbce31c85974c8a661d8612c"
        ></script>
      </div>
    </section>

    <main class="container py-5">
      <h1 class="fw-bold mb-3 text-center">24-Hour Mobile Tyre Service</h1>
      <h2 class="text-center h5 mb-3">
        Fast and Reliable Tyre Replacements When You Need Them
      </h2>
      <p class="text-center mb-5 pb-5 lead">
        At <strong>Tyre Emergency Ltd</strong>, we know that a flat tyre or
        blowout can happen at the most inconvenient times. Whether you’re at
        home, preparing for a trip to the airport, or on your way to work, our
        24-hour mobile tyre service is here to get you back on the road quickly
        and efficiently.
      </p>
      <h2>Our Services</h2>
      <h3>Immediate Tyre Replacements</h3>
      <p>
        Our primary focus is on providing quick and hassle-free tyre
        replacements. When you call us, our expert technicians will arrive at
        your location with the correct tyre to suit your vehicle. We’ll ensure
        that your new tyres are installed promptly so you can continue your
        journey without delay.
      </p>
      <h2>Why Choose Tyre Emergency Ltd?</h2>
      <ul>
        <li>
          24/7 Availability: We are ready to assist you any time of day or
          night. Emergencies don’t follow a schedule, and neither do we.
        </li>
        <li>
          Expert Technicians: Our experienced team is trained to handle tyre
          replacements efficiently, ensuring your safety and satisfaction.
        </li>
        <li>
          Transparent Pricing: With upfront quotes and no hidden fees, you’ll
          know exactly what to expect before we start any work.
        </li>
      </ul>
      <h2>How It Works</h2>
      <ol>
        <li>
          Contact Us: Call Tyre Emergency Ltd at <a href="tel:03301339311"
            >0330 133 9311</a
          > to let us know your situation and location.
        </li>
        <li>
          Rapid Dispatch: We’ll send a technician to you, equipped with the
          right tools and tyres to get you back on the road quickly.
        </li>
        <li>
          Quick Replacement: Our technician will replace your tyre on-site,
          getting you back to your day in no time.
        </li>
      </ol>
      <h2>Don't Let a Flat Tyre Disrupt Your Plans</h2>
      <p>
        Your time is precious, and a flat tyre shouldn’t hold you back. Trust
        Tyre Emergency Ltd for fast and professional mobile tyre replacements
        that fit your schedule.
      </p>
      <h2>Contact Us Today</h2>
      <p>
        Need immediate assistance? Call Tyre Emergency Ltd at <a
          href="tel:03301339311">0330 133 9311</a
        > now! With our 24-hour mobile tyre service, you’ll be back on your way in
        no time.
      </p>
    </main>
    <section class="bg-dark text-light text-center py-5">
      <div class="container">
        <p class="fs-3 fw-bold">Call Now 24 Hour Assistance</p>
        <a href={`tel:03301339311`} class="call-btn"
          ><i class="bi bi-telephone-fill me-2"></i> 0330 133 9311</a
        >
      </div>
    </section>

    <!-- Bootstrap script -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
      crossorigin="anonymous"></script>
  </body>
</html>

<style>
  #hero {
    background:
      `linear-gradient(0deg, rgba(20, 20, 20, 0.7), rgba(20, 20, 20, 0.9)),
      url("/img/mobile-tyre-fitting.webp") `;
    backgroundsize: "cover";
    backgroundposition: "center";
    backgroundrepeat: "no-repeat";
  }
</style>
